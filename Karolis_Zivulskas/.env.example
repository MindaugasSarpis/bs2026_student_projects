# ============================================================
# RepOps — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# App
ENVIRONMENT=development         # development | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://repops:repops@localhost:5432/repops

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Apify (Facebook scraping)
APIFY_TOKEN=                    # https://console.apify.com/account/integrations
SCRAPER_MAX_POSTS=5             # posts fetched per target per run
SCRAPER_MAX_COMMENTS=50         # comments fetched per post

# Analysis
HATE_SPEECH_THRESHOLD=0.6       # score >= this → post flagged for review

# Admin UI credentials
ADMIN_USERNAME=repops
ADMIN_PASSWORD=changeme

# Observability
PROMETHEUS_PORT=9091            # API metrics port
LOG_FILE=                       # override log path; empty = auto (logs/repops.log)
